{
  "name": "cypress-automation-practice",
  "version": "2.0.0",
  "description": "Enterprise-grade Cypress automation framework with POM and CI/CD",
  "main": "index.js",
  "scripts": {
    "test": "cypress run",
    "test:headed": "cypress run --headed",
    "test:chrome": "cypress run --browser chrome",
    "test:greenkart": "cypress run --spec \"cypress/e2e/GreenKart/**/*\"",
    "clean": "rm -rf cypress/reports",
    "format": "prettier --write \"cypress/**/*.js\""
  },
  "author": "Nikhil Laky",
  "license": "ISC",
  "devDependencies": {
    "cypress": "^13.11.0",
    "prettier": "^3.2.5"
  }
}
